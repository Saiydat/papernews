# Copy this file to `.env` and adjust. Docker Compose reads .env automatically.
# Every value below is optional — docker-compose.yml ships sensible defaults.

# ── LLM backend ────────────────────────────────────────────────────────────
# "anthropic" (default) or "ollama".
LLM_BACKEND=anthropic

# Required when LLM_BACKEND=anthropic. Create a key at
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# ── Ollama (when LLM_BACKEND=ollama) ───────────────────────────────────────
# Endpoint of your Ollama instance.
#   - host Ollama:           http://host.docker.internal:11434  (default)
#   - Ollama in a container:  http://ollama:11434  (same Docker network)
OLLAMA_HOST=http://host.docker.internal:11434
# Model name as known to Ollama (must be pulled first).
OLLAMA_MODEL=mistral
# httpx timeout in seconds for Ollama requests (default 1800).
OLLAMA_TIMEOUT=1800

# ── Performance ────────────────────────────────────────────────────────────
# Concurrent LLM workers. Keep high (8) for Anthropic; set to 1 for Ollama/CPU.
PAPERNEWS_WORKERS=8

# ── Scheduling ─────────────────────────────────────────────────────────────
# Interval-based by default. INGEST_SCHEDULE (if set) overrides the interval.
INGEST_INTERVAL_SECONDS=14400      # every N seconds (default 4h)
# INGEST_SCHEDULE=07:00,18:00      # cron-style fixed times (HH:MM, comma-separated)
INGEST_TIMEZONE=UTC                # IANA tz, used with INGEST_SCHEDULE

# ── Post-ingest delivery hook ──────────────────────────────────────────────
# Executable run after each ingest; receives the new PDF path as $1
# (e.g. push to a reMarkable). Drop the script in ./data/hooks/.
# POST_INGEST_HOOK=/data/hooks/push-to-remarkable.sh
POST_INGEST_HOOK_TIMEOUT=300       # seconds

# ── rmapi config (reMarkable hook only) ────────────────────────────────────
# Host path to your rmapi config dir, mounted read-only into the container.
# RMAPI_CONFIG=./rmapi-config

# ─────────────────────────────────────────────────────────────────────────────
# Example: local Ollama setup (uncomment & replace the values above)
# ─────────────────────────────────────────────────────────────────────────────
# LLM_BACKEND=ollama
# OLLAMA_HOST=http://ollama:11434
# OLLAMA_MODEL=qwen2.5:7b
# PAPERNEWS_WORKERS=1
# OLLAMA_TIMEOUT=3600
# INGEST_SCHEDULE=04:00
# INGEST_TIMEZONE=Europe/Brussels
